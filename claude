cat > ~/.claude/settings.json << 'EOF'
{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Glob",
      "Grep"
    ]
  }
}
EOF

cat ~/.claude/settings.json

# Kill any running claude processes
pkill -f claude

# Then reopen VS Code and start fresh
